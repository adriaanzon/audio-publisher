<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">
    <!--
    This is a quick draft. Improve it later using Tailwind UI:
    https://tailwindui.com/components/application-ui/layout/list-containers
    -->
    <header class="bg-white shadow-md">
        <div class="max-w-2xl mx-auto py-6 px-4">
            <h1 class="text-3xl font-bold text-center text-blue-600">{{ title }}</h1>
        </div>
    </header>

    <main class="max-w-2xl mx-auto p-8">
        <h2 class="text-xl font-semibold text-gray-700 mb-6 text-center">Files</h2>
        <ul class="space-y-4">
            {% for file in files %}
            <li class="flex justify-between items-center p-4 bg-white rounded-lg shadow hover:shadow-lg transition-shadow duration-300 ease-in-out">
                <a href="{{ file.url }}" class="text-lg text-blue-500 hover:underline">
                    {{ file.name }}
                </a>
                <span class="text-gray-400 text-sm">[Download]</span>
            </li>
            {% endfor %}
        </ul>
    </main>
</body>
</html>
